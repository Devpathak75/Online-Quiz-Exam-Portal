<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- ================= LOGIN SERVLET ================= -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.quiz.servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

<servlet>
    <servlet-name>AdminLoginServlet</servlet-name>
    <servlet-class>com.quiz.servlet.AdminLoginServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AdminLoginServlet</servlet-name>
    <url-pattern>/AdminLoginServlet</url-pattern>
</servlet-mapping>

    <!-- ============== QUESTION SERVLET ================= -->
    <servlet>
        <servlet-name>QuestionServlet</servlet-name>
        <servlet-class>com.quiz.servlet.QuestionServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>QuestionServlet</servlet-name>
        <url-pattern>/QuestionServlet</url-pattern>
    </servlet-mapping>

<servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.quiz.servlet.LogoutServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/LogoutServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>PdfServlet</servlet-name>
    <servlet-class>com.quiz.servlet.PdfServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>PdfServlet</servlet-name>
    <url-pattern>/PdfServlet</url-pattern>
</servlet-mapping>

<servlet>

    <servlet-name>AdminVerifyOtpServlet</servlet-name>

    <servlet-class>

        com.quiz.servlet.AdminVerifyOtpServlet

    </servlet-class>

</servlet>

<servlet-mapping>

    <servlet-name>AdminVerifyOtpServlet</servlet-name>

    <url-pattern>/AdminVerifyOtpServlet</url-pattern>

</servlet-mapping>

<servlet>

    <servlet-name>AdminSendOtpServlet</servlet-name>

    <servlet-class>

        com.quiz.servlet.AdminSendOtpServlet

    </servlet-class>

</servlet>

<servlet-mapping>

    <servlet-name>AdminSendOtpServlet</servlet-name>

    <url-pattern>/AdminSendOtpServlet</url-pattern>

</servlet-mapping>

    <!-- ================= DEFAULT WELCOME ================= -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>